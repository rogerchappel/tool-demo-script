{
  "name": "@rogerchappel/tool-demo-script",
  "version": "1.0.0",
  "description": "Create runnable demo scripts and narration from a CLI repo, then verify the commands still work.",
  "main": "src/index.js",
  "bin": {
    "tool-demo-script": "bin/tool-demo-script.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "check": "node --check src/*.js",
    "smoke": "bin/tool-demo-script.js demo --repo fixtures/fixture-cli --demo-out fixtures/demo-md",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "demo",
    "verification",
    "agent-skill",
    "testing",
    "readme"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/tool-demo-script.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/tool-demo-script/issues"
  },
  "homepage": "https://github.com/rogerchappel/tool-demo-script#readme",
  "files": [
    "src",
    "bin",
    "fixtures",
    "docs",
    "scripts",
    "README.md"
  ]
}
